[user]
	name = João Vitor Martins Neto
	email = fukurouroy@pm.me
	signingkey = SIGNING_KEY_PLACEHOLDER

[core]
	editor = nano
	autocrlf = input

[pull]
	rebase = true

[init]
	defaultBranch = main

[gpg]
	format = ssh

[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers

[commit]
	gpgsign = true
